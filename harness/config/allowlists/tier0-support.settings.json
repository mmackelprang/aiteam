{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(sudo:*)",
      "Bash(rm:*)",
      "Bash(docker:*)",
      "Bash(ssh:*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ]
  }
}
