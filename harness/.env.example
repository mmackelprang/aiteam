# Copy to .env (gitignored). Never commit real values.
# D5 (plan §5): the pilot authenticates via the Claude subscription —
# one-time `claude login` on each execution host; leave ANTHROPIC_API_KEY
# unset unless/until switching to API-key billing. If set, adapters
# reference it via Paperclip secret syntax (${secrets.anthropic_key}),
# never hardcoded — see HANDOFF §4.3.
ANTHROPIC_API_KEY=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
GOOGLE_CHAT_WEBHOOK_URL=   # single-webhook fallback; per-agent identities use
                           # GOOGLE_CHAT_WEBHOOK_URL__<PROJECT>__<ROLE> vars, mapped in
                           # config/notification_routing/<project>.yaml (F14 in docs/implementation-plan.md)

# Phase 2 only (two-way Chat app — do not create until that phase is approved; proposal §11.4):
# GOOGLE_CLOUD_SERVICE_ACCOUNT_CREDENTIALS=
